<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Peripheria Launcher</title>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;700&display=swap" rel="stylesheet">
    <style>
        /* General Page Styling */
        body, html {
            margin: 0;
            padding: 0;
            height: 100%;
            background-color: #050505;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            font-family: 'Montserrat', sans-serif;
            overflow: hidden;
        }

        /* Container for Buttons */
        .button-wrapper {
            display: flex;
            flex-wrap: wrap;
            gap: 30px;
            justify-content: center;
            align-items: center;
            z-index: 1;
        }

        a {
            text-decoration: none;
        }

        /* Button Styling */
        .btn {
            position: relative;
            display: flex;
            justify-content: center;
            align-items: center;
            width: 16rem; /* Slightly widened for text fit */
            height: 3.5rem;
            border-radius: 5rem;
            background: linear-gradient(#000, #000), linear-gradient(135deg, black, black);
            border: double 3px transparent;
            background-origin: border-box;
            background-clip: content-box, border-box;
            cursor: pointer;
            overflow: hidden;
            transition: 0.4s;
            box-shadow: 0 0 10px black, inset 0 0 10px black, 0 4px 12px black;
        }

        .btn:hover {
            transform: scale(1.08);
            box-shadow: 0 0 20px rgba(255, 255, 255, 0.9), inset 0 0 25px white, 0 6px 25px white;
        }

        .btn strong {
            position: relative;
            z-index: 2;
            font-size: 13px;
            letter-spacing: 2px;
            color: #fff;
            text-transform: uppercase;
            text-shadow: 0 0 6px black;
        }

        /* Stars Background inside buttons */
        #container-stars {
            position: absolute;
            z-index: 0;
            width: 100%;
            height: 100%;
            overflow: hidden;
            border-radius: 5rem;
            backdrop-filter: blur(0.8rem);
        }

        #stars {
            position: relative;
            background: transparent;
            width: 200rem;
            height: 200rem;
        }

        #stars::after {
            content: "";
            position: absolute;
            top: -10rem;
            left: -100rem;
            width: 100%;
            height: 100%;
            animation: rotateStars 90s linear infinite;
            background-image: radial-gradient(white 1px, transparent 1%);
            background-size: 50px 50px;
        }

        /* Glow effect inside buttons */
        #glow {
            position: absolute;
            display: flex;
            width: 12rem;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            pointer-events: none;
            z-index: 1;
        }

        .circle {
            width: 100%;
            height: 30px;
            filter: blur(2rem);
            background: white;
            opacity: 0.2;
            border-radius: 50%;
            animation: pulseGlow 4s infinite;
        }

        /* Announcement Banner */
        #announcement-banner {
            position: fixed;
            bottom: 30px;
            right: 30px;
            z-index: 10000;
            width: 500px;
            padding: 25px;
            background-color: #1a1a1a;
            color: #ffffff;
            border-radius: 12px;
            border: 2px solid #ffffff;
            box-shadow: 0 0 15px rgba(255, 255, 255, 0.5);
            animation: slideIn 0.6s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards, pulseBanner 2s infinite ease-in-out;
        }

        .banner-content {
            display: flex;
            align-items: center;
            gap: 20px;
        }

        .banner-content p {
            margin: 0;
            font-size: 18px;
            line-height: 1.5;
            font-weight: 600;
        }

        .banner-icon {
            font-size: 32px;
        }

        /* Animations */
        @keyframes rotateStars {
            from { transform: rotate(0deg); }
            to { transform: rotate(360deg); }
        }

        @keyframes pulseGlow {
            0%, 100% { transform: scale(0.8); opacity: 0.15; }
            70% { transform: scale(1); opacity: 0.3; }
        }

        @keyframes slideIn {
            from { transform: translateX(120%); opacity: 0; }
            to { transform: translateX(0); opacity: 1; }
        }

        @keyframes pulseBanner {
            0%, 100% { box-shadow: 0 0 10px rgba(255, 255, 255, 0.4); border-color: rgba(255, 255, 255, 0.6); }
            50% { box-shadow: 0 0 25px rgba(255, 255, 255, 0.8); border-color: rgba(255, 255, 255, 1); }
        }

        /* Mobile Adjustments */
        @media (max-width: 600px) {
            #announcement-banner {
                width: calc(100% - 40px);
                bottom: 10px;
                right: 20px;
                left: 20px;
                padding: 15px;
            }
            .banner-content p { font-size: 14px; }
            .button-wrapper { flex-direction: column; }
        }
    </style>
</head>
<body>

    <div class="button-wrapper">
        <a href="https://cdn.jsdelivr.net/gh/lucideproxy/svg@latest/logo.svg#/" target="_blank">
            <button class="btn" type="button">
                <strong>LAUNCH LUCIDE</strong>
                <div id="container-stars"><div id="stars"></div></div>
                <div id="glow"><div class="circle"></div><div class="circle"></div></div>
            </button>
        </a>

        <a href="https://sites.google.com/view/peripheria-ex/pr_xes/vapor-v4" target="_blank">
            <button class="btn" type="button">
                <strong>LAUNCH VAPOR V4</strong>
                <div id="container-stars"><div id="stars"></div></div>
                <div id="glow"><div class="circle"></div><div class="circle"></div></div>
            </button>
        </a>
    </div>

    <div id="announcement-banner">
        <div class="banner-content">
            <span class="banner-icon">⚠️</span>
            <p>The Proxies listed here might not always be fully functional. We will try to update frequently!</p>
        </div>
    </div>

</body>
</html>
