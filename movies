const imageCache={};
let activeId=null;
let currentList=[...MOVIES];

function previewUrl(id){return`https://drive.google.com/file/d/${id}/preview`}
function driveUrl(id){return`https://drive.google.com/file/d/${id}/view`}

async function fetchWikiBatch(movies){
  const titles=movies.map(m=>m.wt).join('|');
  const url=`https://en.wikipedia.org/w/api.php?action=query&prop=pageimages&pithumbsize=500&format=json&origin=*&redirects=1&titles=${encodeURIComponent(titles)}`;
  try{
    const r=await fetch(url);
    const data=await r.json();
    const normMap={};
    for(const n of(data.query.normalized||[])) normMap[n.from]=n.to;
    for(const rd of(data.query.redirects||[])) normMap[rd.from]=rd.to;
    const byTitle={};
    for(const pg of Object.values(data.query.pages||{})){
      if(pg.thumbnail) byTitle[pg.title]=pg.thumbnail.source;
    }
    for(const m of movies){
      const canonical=normMap[m.wt]||m.wt;
      imageCache[m.wt]=byTitle[canonical]||byTitle[m.wt]||null;
    }
  }catch(e){
    for(const m of movies) imageCache[m.wt]=null;
  }
}

function applyImage(m){
  const card=document.getElementById('c-'+m.id);
  if(!card) return;
  const shimmer=card.querySelector('.card-shimmer');
  const img=card.querySelector('img');
  const fb=card.querySelector('.card-fb');
  const src=imageCache[m.wt];
  if(shimmer) shimmer.remove();
  if(src){
    img.onload=()=>img.classList.add('loaded');
    img.onerror=()=>{img.style.display='none';fb.style.display='flex';};
    img.src=src;
  } else {
    img.style.display='none';
    fb.style.display='flex';
  }
}

async function loadAllImages(){
  const batchSize=45;
  const status=document.getElementById('statusbar');
  let loaded=0;
  for(let i=0;i<MOVIES.length;i+=batchSize){
    const batch=MOVIES.slice(i,i+batchSize);
    await fetchWikiBatch(batch);
    batch.forEach(m=>applyImage(m));
    loaded+=batch.length;
    status.textContent=`Loaded ${Math.min(loaded,MOVIES.length)} / ${MOVIES.length} posters`;
  }
  status.textContent='';
}

function buildGrid(list){
  const grid=document.getElementById('grid');
  grid.innerHTML='';
  list.forEach(m=>{
    const card=document.createElement('div');
    card.className='card'+(m.id===activeId?' active':'');
    card.id='c-'+m.id;
    card.onclick=()=>playMovie(m.id,m.title);
    const inner=document.createElement('div');
    inner.className='card-inner';
    const shimmer=document.createElement('div');
    shimmer.className='card-shimmer';
    const img=document.createElement('img');
    img.alt=m.title;
    img.loading='lazy';
    const fb=document.createElement('div');
    fb.className='card-fb';
    fb.style.display='none';
    fb.innerHTML=`<div class="card-fb-icon">${m.icon}</div><div class="card-fb-txt">${m.title}</div>`;
    const overlay=document.createElement('div');
    overlay.className='card-overlay';
    overlay.innerHTML=`<div class="card-play"><svg width="8" height="10" viewBox="0 0 8 10" fill="#fff"><polygon points="0,0 8,5 0,10"/></svg></div><div class="card-ttl">${m.title}</div>`;
    inner.appendChild(shimmer);
    inner.appendChild(img);
    inner.appendChild(fb);
    inner.appendChild(overlay);
    card.appendChild(inner);
    grid.appendChild(card);
    if(imageCache[m.wt]!==undefined) applyImage(m);
  });
  document.getElementById('seccnt').textContent=` \u2014 ${list.length} titles`;
  document.getElementById('cnt').textContent=`${list.length} movies`;
}

function playMovie(id,title){
  document.querySelector('.card.active')?.classList.remove('active');
  activeId=id;
  document.getElementById('c-'+id)?.classList.add('active');
  const iframe=document.getElementById('pifr');
  iframe.src=previewUrl(id);
  iframe.classList.add('on');
  document.getElementById('pph').style.display='none';
  document.getElementById('pcls').classList.add('on');
  document.getElementById('plbl').innerHTML=`Now playing &nbsp;&bull;&nbsp; <b style="color:#e50914">${title}</b><a href="${driveUrl(id)}" target="_blank" class="opnlnk">Open in Drive \u2197</a>`;
}

function closePlayer(){
  const iframe=document.getElementById('pifr');
  iframe.src='';iframe.classList.remove('on');
  document.getElementById('pph').style.display='';
  document.getElementById('pcls').classList.remove('on');
  document.getElementById('plbl').textContent='Now playing';
  document.querySelector('.card.active')?.classList.remove('active');
  activeId=null;
}

function doFilter(){
  const q=document.getElementById('srch').value.trim().toLowerCase();
  currentList=q?MOVIES.filter(m=>m.title.toLowerCase().includes(q)):[...MOVIES];
  buildGrid(currentList);
  document.getElementById('nores').style.display=currentList.length===0?'block':'none';
}

buildGrid(MOVIES);
loadAllImages();
</script>
