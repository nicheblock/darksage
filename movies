<style>
*{box-sizing:border-box;margin:0;padding:0}
.wrap{background:#141414;min-height:600px;font-family:'Trebuchet MS',sans-serif;color:#fff;padding-bottom:3rem}
.hdr{background:linear-gradient(180deg,#000 0%,transparent 100%);padding:.9rem 1.4rem;display:flex;align-items:center;gap:1rem;position:sticky;top:0;z-index:20}
.logo{font-size:1.5rem;font-weight:900;color:#e50914;letter-spacing:-1px;flex-shrink:0}
.srch{background:rgba(255,255,255,0.08);border:1px solid rgba(255,255,255,0.15);border-radius:4px;padding:5px 11px;color:#fff;font-size:13px;width:160px;outline:none}
.srch::placeholder{color:rgba(255,255,255,0.35)}
.cnt{font-size:12px;color:rgba(255,255,255,0.35);margin-left:auto}
.player-area{position:relative;background:#000;width:100%}
.plbl{position:absolute;top:10px;left:14px;font-size:11px;color:rgba(255,255,255,0.45);letter-spacing:1px;text-transform:uppercase;z-index:2}
.pcls{position:absolute;top:8px;right:12px;background:rgba(255,255,255,0.12);border:none;color:#fff;border-radius:50%;width:26px;height:26px;cursor:pointer;font-size:14px;line-height:26px;text-align:center;z-index:2;display:none}
.pcls.on{display:block}
.pifr{width:100%;height:0;border:none;transition:height .3s}
.pifr.on{height:360px}
.pph{width:100%;height:160px;display:flex;align-items:center;justify-content:center;flex-direction:column;gap:8px;color:rgba(255,255,255,0.18);font-size:13px}
.sectitle{padding:1rem 1.4rem .5rem;font-size:.95rem;font-weight:700;color:#e5e5e5}
.sectitle small{font-weight:400;color:rgba(255,255,255,0.35);font-size:.78rem;margin-left:6px}
.grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(110px,1fr));gap:6px;padding:0 1.4rem}
.card{position:relative;border-radius:5px;overflow:hidden;cursor:pointer;width:100%;padding-top:150%;background:#1a1a2e;transition:transform .15s,box-shadow .15s}
.card:hover{transform:scale(1.06);box-shadow:0 8px 30px rgba(0,0,0,0.9);z-index:3}
.card.active{outline:3px solid #e50914}
.card-inner{position:absolute;inset:0}
.card-inner img{width:100%;height:100%;object-fit:cover;display:none}
.card-inner img.loaded{display:block}
.card-fb{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:5px;padding:8px;text-align:center;background:#1c1c2e}
.card-fb-icon{font-size:22px}
.card-fb-txt{font-size:9px;color:rgba(255,255,255,0.55);font-weight:700;line-height:1.3}
@keyframes shimmer{0%{background-position:-400px 0}100%{background-position:400px 0}}
.card-shimmer{position:absolute;inset:0;background:linear-gradient(90deg,#1a1a2e 0%,#2d2d50 50%,#1a1a2e 100%);background-size:800px 100%;animation:shimmer 1.4s infinite linear}
.card-overlay{position:absolute;inset:0;background:linear-gradient(to top,rgba(0,0,0,0.95) 0%,transparent 55%);opacity:0;transition:opacity .15s;display:flex;flex-direction:column;justify-content:flex-end;padding:7px;pointer-events:none}
.card:hover .card-overlay,.card.active .card-overlay{opacity:1}
.card-play{width:22px;height:22px;background:#e50914;border-radius:50%;display:flex;align-items:center;justify-content:center;margin-bottom:4px}
.card-ttl{font-size:9px;color:#fff;font-weight:700;line-height:1.3}
.nores{padding:2rem;text-align:center;color:rgba(255,255,255,0.28);font-size:14px;display:none}
.opnlnk{margin-left:8px;padding:3px 10px;background:#e50914;color:#fff;font-size:11px;border-radius:3px;text-decoration:none;font-weight:700}
.status-bar{padding:4px 1.4rem;font-size:11px;color:rgba(255,255,255,0.3)}
</style>

