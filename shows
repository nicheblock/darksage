<style>
:root {
    --bg: #1f1f1f;          /* Brighter Charcoal Background */
    --surface: #2d2d2d;     /* Panel Surface */
    --card: #353535;        /* Card Surface */
    --accent: #e50914;      /* Netflix Red */
    --text: #f5f5f5;
    --text-dim: #999;
    --border: #444;
}

body {
    background: var(--bg);
    color: var(--text);
    font-family: 'Inter', system-ui, -apple-system, sans-serif;
    margin: 0;
}

/* Header */
.hdr {
    background: var(--surface);
    padding: 1rem 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-bottom: 1px solid var(--border);
    position: sticky;
    top: 0;
    z-index: 100;
}

.logo { font-size: 1.5rem; font-weight: 900; color: var(--accent); letter-spacing: 1px; }

.srch {
    background: #111;
    border: 1px solid var(--border);
    padding: 10px 20px;
    border-radius: 30px;
    color: white;
    width: 300px;
    outline: none;
    transition: 0.2s;
}
.srch:focus { border-color: var(--accent); width: 350px; }

/* Theater Mode */
.theater {
    display: none;
    grid-template-columns: 350px 1fr;
    height: 600px;
    background: #000;
    border-bottom: 2px solid var(--border);
}
.theater.active { display: grid; }

.side-nav { background: var(--surface); border-right: 1px solid var(--border); display: flex; flex-direction: column; }
.nav-hint { padding: 12px; font-size: 11px; background: #222; color: var(--text-dim); text-align: center; border-bottom: 1px solid var(--border); }

.player-main { display: flex; flex-direction: column; background: #000; }
.sync-controls { padding: 10px; background: var(--surface); display: flex; gap: 10px; border-bottom: 1px solid var(--border); }
.url-input { flex-grow: 1; padding: 10px; background: #111; border: 1px solid var(--border); color: #00ff41; border-radius: 4px; font-family: monospace; font-size: 12px; }
.btn-watch { background: var(--accent); color: white; border: none; padding: 0 20px; font-weight: bold; border-radius: 4px; cursor: pointer; }
.btn-x { background: #444; border: none; color: white; padding: 0 15px; border-radius: 4px; cursor: pointer; }

/* Grid */
.container { padding: 2rem; }
.grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(170px, 1fr)); gap: 20px; }

.card {
    background: var(--card);
    border-radius: 10px;
    aspect-ratio: 2/3;
    position: relative;
    overflow: hidden;
    cursor: pointer;
    transition: 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    border: 1px solid var(--border);
}
.card:hover { transform: translateY(-8px); border-color: var(--accent); box-shadow: 0 10px 30px rgba(0,0,0,0.5); }

/* Card Content & Fallback */
.card img { width: 100%; height: 100%; object-fit: cover; position: absolute; inset: 0; opacity: 0; transition: opacity 0.5s; z-index: 2; }
.card img.loaded { opacity: 1; }

.card-fb {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 20px;
    text-align: center;
    background: linear-gradient(135deg, #333 0%, #1f1f1f 100%);
    z-index: 1;
}
.fb-icon { font-size: 48px; margin-bottom: 10px; opacity: 0.8; }
.fb-text { font-size: 14px; font-weight: 700; line-height: 1.3; }

iframe { width: 100%; height: 100%; border: none; }
</style>

<div class="hdr">
    <div class="logo">PERIPHERIA</div>
    <input type="text" class="srch" placeholder="Find a show..." oninput="doSearch(this.value)">
</div>

<div class="theater" id="theater">
    <div class="side-nav">
        <div class="nav-hint">Select file > Copy Link > Paste here</div>
        <iframe id="nav-frame"></iframe>
    </div>
    <div class="player-main">
        <div class="sync-controls">
            <input type="text" id="link-input" class="url-input" placeholder="Paste the episode link here...">
            <button class="btn-watch" onclick="startPlay()">WATCH</button>
            <button class="btn-x" onclick="closeTheater()">✕</button>
        </div>
        <iframe id="play-frame" allowfullscreen allow="autoplay"></iframe>
    </div>
</div>

<div class="container">
    <div class="grid" id="grid"></div>
</div>

<script>
// I added the Emojis back here so they show up if the image fails!
const SHOWS = [
  {id:"1xewFLZCNhjF5DtQDM5VxDic7ClprMjal", title:"Invincible", em:"🦸"},
  {id:"11W6C-Jqv9iQVasqjfiaYz77puax1UTjH", title:"Family Guy", em:"👨‍👩‍👧‍👦"},
  {id:"1PzKaoaK4blzlaoxnwC20gZoeYE5mDxWL", title:"South Park", em:"🏔️"},
  {id:"0B4MmtgsAR4q4fmFVY1c2WkF6WnplaEEzeThkVFhSQkxQRFVRS0pHRjlLVlZlaW8yS0xxbXM", title:"Death Note", em:"📓"},
  {id:"1gvqxyzUzlH_xjNA13NCj0jmnc-KwqTfQ", title:"Naruto Shippuden", em:"🍥"},
  {id:"15GtJc8NKaGoZyPoRXcJjTs6ZSQfKJ-xb", title:"Ninjago", em:"🥷"},
  {id:"1OFWN8hASAuNWSn9mK2gANJ0PSQhvIA2r", title:"Avatar: The Last Airbender", em:"🌬️"},
  {id:"1j_K1YV4w_sHAzwEAaUMl-qSk4qjrYSJ_", title:"The Cuphead Show!", em:"☕"},
  {id:"1nW610bRzpYobTHqK5k13LRkiZrRvDmZ8", title:"Moon Knight", em:"🌙"},
  {id:"1BVkiWaMVA1mZ1J2bJcnE3_ywvNFg1IKP", title:"Euphoria", em:"💊"},
  {id:"1eqNcKK02wEdRV7RnfrmDRZf2s2QZHUyj", title:"Jujutsu Kaisen", em:"🤞"},
  {id:"1tedaT2-lJvdIToqgsBx7lDo4tJl3TY-U", title:"Regular Show", em:"🐦"},
  {id:"1cOFMumtLFERJqS6Y5oTyBb6ZRXNHCgZF", title:"SpongeBob SquarePants", em:"🧽"},
  {id:"1OXgcS7q8GexG3oOHxSMDuNYfUo-BMVxq", title:"The Amazing World of Gumball", em:"🐱"},
  {id:"1AXfTn4tO2rPY806SOgqK0uZQwwUylS0J", title:"The Legend of Korra", em:"🌊"},
  {id:"1SIvo_3pKpUesX4ZDY2Y7Z59kXe632XWe", title:"One Piece", em:"🏴‍☠️"},
  {id:"11CP20VTJqf7a2gjsLLOOu88xBropDjl2", title:"Spider-Man: The Animated Series", em:"🕷️"},
  {id:"1tXo2krTMvXr-ATSqthy55PUpRRIu1HRr", title:"The Simpsons", em:"🍩"},
  {id:"1mJpyJawm4TPb0Zgi7oW46mlnLS4qkBuD", title:"The Boondocks", em:"✊🏾"},
  {id:"1ujarzaX_90FGOiRC15OmXOAgwSbdI_kA", title:"Squid Game", em:"🦑"},
  {id:"1nitUTtOlz-R8Qc5eEUf7F-5H21WyGWyF", title:"Dexter", em:"🔪"},
  {id:"1h_pnGrifrJnpbP0H59oKqpo3dbCv5TSl", title:"Blue Lock", em:"⚽"},
  {id:"1IHdz8cHiQpTF2wezd3cDemASm6c08c8d", title:"Wednesday", em:"🖤"},
  {id:"1L_4PmRvkuqYsvLQSzMuaqRVDQg2pb9Z6", title:"The Last of Us", em:"🍄"},
  {id:"1HOYzXLzNkTTfzpAWmvMWSJaJ9kLo_PZF", title:"Steven Universe", em:"💎"},
  {id:"1XAUQ6L7C2p_HU6l4JXwRV7Q8gFj9gCg7", title:"Loki", em:"⏳"},
  {id:"1DxliwM034LQ7181RTdf0vRhfvWCPgT5t", title:"Breaking Bad", em:"🧪"}
];

const posters = {};

async function getPoster(title) {
    try {
        const r = await fetch(`https://api.tvmaze.com/singlesearch/shows?q=${encodeURIComponent(title)}`);
        const data = await r.json();
        return data.image ? data.image.medium : null;
    } catch(e) { return null; }
}

async function loadAll() {
    for (let s of SHOWS) {
        posters[s.title] = await getPoster(s.title);
        // Refresh grid as they load so user doesn't wait
        refreshGrid(SHOWS);
    }
}

function refreshGrid(list) {
    const grid = document.getElementById('grid');
    grid.innerHTML = "";
    list.forEach(s => {
        const card = document.createElement('div');
        card.className = 'card';
        card.onclick = () => openShow(s.id);
        
        const imgPath = posters[s.title];
        card.innerHTML = `
            <div class="card-fb">
                <div class="fb-icon">${s.em}</div>
                <div class="fb-text">${s.title}</div>
            </div>
            ${imgPath ? `<img src="${imgPath}" onload="this.classList.add('loaded')">` : ''}
        `;
        grid.appendChild(card);
    });
}

function openShow(id) {
    document.getElementById('theater').classList.add('active');
    document.getElementById('nav-frame').src = `https://drive.google.com/embeddedfolderview?id=${id}#list`;
    window.scrollTo({top: 0, behavior: 'smooth'});
}

function startPlay() {
    const val = document.getElementById('link-input').value;
    let fileId = "";
    if (val.includes('file/d/')) fileId = val.split('file/d/')[1].split('/')[0];
    else if (val.includes('id=')) fileId = val.split('id=')[1].split('&')[0];

    if (fileId) {
        document.getElementById('play-frame').src = `https://drive.google.com/file/d/${fileId}/preview`;
    }
}

function closeTheater() {
    document.getElementById('theater').classList.remove('active');
    document.getElementById('nav-frame').src = "";
    document.getElementById('play-frame').src = "";
}

function doSearch(val) {
    const filtered = SHOWS.filter(s => s.title.toLowerCase().includes(val.toLowerCase()));
    refreshGrid(filtered);
}

loadAll();
</script>
